PORT=3002
NODE_ENV=development

# DB adapter: memory (local smoke) or postgres (real persistence)
DB_DRIVER=memory
DATABASE_URL=postgres://nova:nova@localhost:5432/nova
DB_POOL_MAX=10
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Security controls
REQUIRE_TLS=true
TRUST_PROXY=true
SECURITY_STRICT_RBAC=true
AUDIT_HASH_ALGO=sha256
AUDIT_APPEND_ONLY=true
AUDIT_RETENTION_DAYS=2555

# HIPAA deployment controls (policy declarations)
ENCRYPTION_AT_REST=provider-managed-kms
ENCRYPTION_IN_TRANSIT=tls1.2+
PHI_LOG_REDACTION=true

# ─────────────────────────────────────────────
# QuickBooks Online (QBO) Integration
# Docs: https://developer.intuit.com/app/developer/qbo/docs
# ─────────────────────────────────────────────
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REALM_ID=
QBO_ACCESS_TOKEN=
QBO_REFRESH_TOKEN=
QBO_SANDBOX=true

# ─────────────────────────────────────────────
# Twilio (SMS / Voice)
# Docs: https://www.twilio.com/docs/usage/api
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# ─────────────────────────────────────────────
# Mailchimp (Email Marketing)
# Docs: https://mailchimp.com/developer/marketing/api/
# Format: <key>-<datacenter>  e.g. abc123-us6
# ─────────────────────────────────────────────
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER_PREFIX=

# ─────────────────────────────────────────────
# Google Business Profile
# Docs: https://developers.google.com/my-business/reference/rest
# Scopes: https://www.googleapis.com/auth/business.manage
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_BUSINESS_ACCESS_TOKEN=
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_LOCATION_ID=

# ─────────────────────────────────────────────
# OpenAI
# Docs: https://platform.openai.com/docs/api-reference
# ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
